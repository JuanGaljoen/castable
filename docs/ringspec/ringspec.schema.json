{
  "$defs": {
    "FieldConfidence": {
      "additionalProperties": false,
      "description": "Per-field vision confidence (0..1). RNG-12 populates; None until then.",
      "properties": {
        "inner_diameter": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inner Diameter"
        },
        "band_width": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Band Width"
        },
        "band_thickness": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Band Thickness"
        },
        "stone_diameter": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stone Diameter"
        },
        "stone_height": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stone Height"
        },
        "prong_count": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prong Count"
        },
        "setting_height": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Setting Height"
        }
      },
      "title": "FieldConfidence",
      "type": "object"
    },
    "Halo": {
      "additionalProperties": false,
      "description": "Accent-stone ring encircling the centre stone (RNG-9).",
      "properties": {
        "halo_stone_diameter": {
          "default": 1.3,
          "maximum": 2.5,
          "minimum": 0.9,
          "title": "Halo Stone Diameter",
          "type": "number"
        },
        "halo_stone_count": {
          "default": 14,
          "maximum": 24,
          "minimum": 8,
          "title": "Halo Stone Count",
          "type": "integer"
        },
        "halo_gap": {
          "default": 0.5,
          "maximum": 1.5,
          "minimum": 0.3,
          "title": "Halo Gap",
          "type": "number"
        },
        "halo_stone_height": {
          "default": 1.2,
          "maximum": 3.0,
          "minimum": 0.8,
          "title": "Halo Stone Height",
          "type": "number"
        }
      },
      "title": "Halo",
      "type": "object"
    },
    "HaloSpec": {
      "additionalProperties": false,
      "description": "Halo archetype: a solitaire centre plus a ring of accent stones.",
      "properties": {
        "version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Version",
          "type": "string"
        },
        "archetype": {
          "const": "halo",
          "default": "halo",
          "title": "Archetype",
          "type": "string"
        },
        "shank": {
          "$ref": "#/$defs/Shank"
        },
        "setting": {
          "$ref": "#/$defs/Setting"
        },
        "stones": {
          "$ref": "#/$defs/Stones"
        },
        "halo": {
          "$ref": "#/$defs/Halo"
        },
        "motifs": {
          "items": {
            "$ref": "#/$defs/Motif"
          },
          "title": "Motifs",
          "type": "array"
        },
        "confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/FieldConfidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "shank",
        "setting",
        "stones",
        "halo"
      ],
      "title": "HaloSpec",
      "type": "object"
    },
    "Motif": {
      "additionalProperties": false,
      "description": "Decorative element placeholder (empty list is valid for a solitaire).",
      "properties": {
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "position": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Position"
        }
      },
      "required": [
        "kind"
      ],
      "title": "Motif",
      "type": "object"
    },
    "Setting": {
      "additionalProperties": false,
      "description": "Prong/gallery group. prong_count is a strict 4-or-6 literal.",
      "properties": {
        "prong_count": {
          "enum": [
            4,
            6
          ],
          "title": "Prong Count",
          "type": "integer"
        },
        "setting_height": {
          "exclusiveMinimum": 0,
          "maximum": 20,
          "title": "Setting Height",
          "type": "number"
        }
      },
      "required": [
        "prong_count",
        "setting_height"
      ],
      "title": "Setting",
      "type": "object"
    },
    "Shank": {
      "additionalProperties": false,
      "description": "Band geometry. shank_taper is the SCAD 8th shaping param (default 1.7).",
      "properties": {
        "inner_diameter": {
          "exclusiveMinimum": 0,
          "maximum": 40,
          "title": "Inner Diameter",
          "type": "number"
        },
        "band_width": {
          "exclusiveMinimum": 0,
          "maximum": 12,
          "title": "Band Width",
          "type": "number"
        },
        "band_thickness": {
          "exclusiveMinimum": 0,
          "maximum": 8,
          "title": "Band Thickness",
          "type": "number"
        },
        "shank_taper": {
          "default": 1.7,
          "maximum": 3.0,
          "minimum": 1.0,
          "title": "Shank Taper",
          "type": "number"
        }
      },
      "required": [
        "inner_diameter",
        "band_width",
        "band_thickness"
      ],
      "title": "Shank",
      "type": "object"
    },
    "SideStone": {
      "additionalProperties": false,
      "description": "Channel-set accent row down each shoulder of the shank (RNG-11).\n\n`retention` is a Literal[\"channel\"] in v1 \u2014 pave is a future value; a\n\"pave\" spec is a clean schema rejection today, not a shipped-but-broken\noption (specs/RNG-11.md Decision 5).",
      "properties": {
        "accent_stone_diameter": {
          "default": 1.5,
          "maximum": 2.5,
          "minimum": 0.9,
          "title": "Accent Stone Diameter",
          "type": "number"
        },
        "accent_stone_height": {
          "default": 1.2,
          "maximum": 3.0,
          "minimum": 0.8,
          "title": "Accent Stone Height",
          "type": "number"
        },
        "accent_count_per_side": {
          "default": 3,
          "maximum": 8,
          "minimum": 1,
          "title": "Accent Count Per Side",
          "type": "integer"
        },
        "accent_gap": {
          "default": 0.3,
          "maximum": 1.0,
          "minimum": 0.2,
          "title": "Accent Gap",
          "type": "number"
        },
        "retention": {
          "const": "channel",
          "default": "channel",
          "title": "Retention",
          "type": "string"
        }
      },
      "title": "SideStone",
      "type": "object"
    },
    "SideStoneSpec": {
      "additionalProperties": false,
      "description": "Side-stone archetype: a solitaire centre plus a channel-set accent row\ndown each shoulder.",
      "properties": {
        "version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Version",
          "type": "string"
        },
        "archetype": {
          "const": "side_stone",
          "default": "side_stone",
          "title": "Archetype",
          "type": "string"
        },
        "shank": {
          "$ref": "#/$defs/Shank"
        },
        "setting": {
          "$ref": "#/$defs/Setting"
        },
        "stones": {
          "$ref": "#/$defs/Stones"
        },
        "side_stone": {
          "$ref": "#/$defs/SideStone"
        },
        "motifs": {
          "items": {
            "$ref": "#/$defs/Motif"
          },
          "title": "Motifs",
          "type": "array"
        },
        "confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/FieldConfidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "shank",
        "setting",
        "stones",
        "side_stone"
      ],
      "title": "SideStoneSpec",
      "type": "object"
    },
    "SolitaireSpec": {
      "additionalProperties": false,
      "description": "Solitaire archetype: one centre stone in a prong setting on a shank.",
      "properties": {
        "version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Version",
          "type": "string"
        },
        "archetype": {
          "const": "solitaire",
          "default": "solitaire",
          "title": "Archetype",
          "type": "string"
        },
        "shank": {
          "$ref": "#/$defs/Shank"
        },
        "setting": {
          "$ref": "#/$defs/Setting"
        },
        "stones": {
          "$ref": "#/$defs/Stones"
        },
        "motifs": {
          "items": {
            "$ref": "#/$defs/Motif"
          },
          "title": "Motifs",
          "type": "array"
        },
        "confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/FieldConfidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "shank",
        "setting",
        "stones"
      ],
      "title": "SolitaireSpec",
      "type": "object"
    },
    "Stones": {
      "additionalProperties": false,
      "description": "Centre-stone sizing and shape for the seat module.\n\n`stone_diameter` is the SHORT axis (the width); the long axis is\n`stone_diameter * length_ratio`. Both shape fields are defaulted, so every\nspec written before RNG-23 stays valid and still means a round stone.\n\nA ratio rather than an explicit length: it is the quantity a photo actually\nshows (feeding RNG-26), and `length_ratio == 1.0` makes round fall out of the\nsame code path instead of needing a branch. The 2.5 cap is a castability\nguard -- an ellipse's tightest bend is `semi_minor^2 / semi_major`, so\nelongation directly thins the metal at the tips.",
      "properties": {
        "stone_diameter": {
          "exclusiveMinimum": 0,
          "maximum": 24,
          "title": "Stone Diameter",
          "type": "number"
        },
        "stone_height": {
          "exclusiveMinimum": 0,
          "maximum": 12,
          "title": "Stone Height",
          "type": "number"
        },
        "shape": {
          "default": "round",
          "enum": [
            "round",
            "oval"
          ],
          "title": "Shape",
          "type": "string"
        },
        "length_ratio": {
          "default": 1.0,
          "maximum": 2.5,
          "minimum": 1.0,
          "title": "Length Ratio",
          "type": "number"
        }
      },
      "required": [
        "stone_diameter",
        "stone_height"
      ],
      "title": "Stones",
      "type": "object"
    },
    "Trilogy": {
      "additionalProperties": false,
      "description": "Side-stone group flanking the centre stone (RNG-10).",
      "properties": {
        "side_stone_diameter": {
          "default": 2.5,
          "maximum": 6.0,
          "minimum": 0.9,
          "title": "Side Stone Diameter",
          "type": "number"
        },
        "side_stone_height": {
          "default": 1.8,
          "maximum": 4.0,
          "minimum": 0.8,
          "title": "Side Stone Height",
          "type": "number"
        },
        "side_stone_gap": {
          "default": 0.6,
          "maximum": 2.0,
          "minimum": 0.3,
          "title": "Side Stone Gap",
          "type": "number"
        }
      },
      "title": "Trilogy",
      "type": "object"
    },
    "TrilogySpec": {
      "additionalProperties": false,
      "description": "Trilogy archetype: a solitaire centre plus two symmetric side stones.",
      "properties": {
        "version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Version",
          "type": "string"
        },
        "archetype": {
          "const": "trilogy",
          "default": "trilogy",
          "title": "Archetype",
          "type": "string"
        },
        "shank": {
          "$ref": "#/$defs/Shank"
        },
        "setting": {
          "$ref": "#/$defs/Setting"
        },
        "stones": {
          "$ref": "#/$defs/Stones"
        },
        "trilogy": {
          "$ref": "#/$defs/Trilogy"
        },
        "motifs": {
          "items": {
            "$ref": "#/$defs/Motif"
          },
          "title": "Motifs",
          "type": "array"
        },
        "confidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/FieldConfidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "shank",
        "setting",
        "stones",
        "trilogy"
      ],
      "title": "TrilogySpec",
      "type": "object"
    }
  },
  "discriminator": {
    "mapping": {
      "halo": "#/$defs/HaloSpec",
      "side_stone": "#/$defs/SideStoneSpec",
      "solitaire": "#/$defs/SolitaireSpec",
      "trilogy": "#/$defs/TrilogySpec"
    },
    "propertyName": "archetype"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/SolitaireSpec"
    },
    {
      "$ref": "#/$defs/HaloSpec"
    },
    {
      "$ref": "#/$defs/TrilogySpec"
    },
    {
      "$ref": "#/$defs/SideStoneSpec"
    }
  ]
}
